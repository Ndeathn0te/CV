export interface Experience {
  dates: string;
  duration: string;
  company: string;
  sector: string;
  role: string;
  location: string;
  project: string;
  summary: string;
  reasonForLeaving?: string;
}

export interface CVData {
  name: string;
  title: string;
  contact: {
    location: string;
    phone: string;
    email: string;
    linkedin: string;
    photo?: string;
  };
  summary: string;
  experience: Experience[];
  earlierExperience: { role: string; company: string; year: string }[];
  technicalSkills: { category: string; skills: string[] }[];
  education: { degree: string; institution: string }[];
  awards: { title: string; issuer: string; year: string; description: string }[];
  certifications: string[];
  languages: { language: string; level: string }[];
}
